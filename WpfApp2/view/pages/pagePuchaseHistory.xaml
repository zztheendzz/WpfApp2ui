<Page x:Class="WpfApp2.view.pages.pagePuchaseHistory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:WpfApp2.viewmodel.tableVm"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1100"
      Title="pagePuchaseHistory">

    <Page.DataContext>
        <vm:PurchaseViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <ComboBox Width="180" 
                          ItemsSource="{Binding ModelCodeList}"
                          SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                          DisplayMemberPath="ModelCode"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_ModelCode}"
                          Margin="0,0,15,0"/>

                <ComboBox Width="180" 
                          ItemsSource="{Binding ModelNameList}"
                          SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                          DisplayMemberPath="ModelName"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_ModelName}"
                          Margin="0,0,15,0"/>

                <ComboBox Width="180" 
                          ItemsSource="{Binding VendorList}"
                          SelectedItem="{Binding SelectedVendor, Mode=TwoWay}"
                          DisplayMemberPath="VendorName"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_Vendor}"
                          Margin="0,0,15,0"/>

                <ComboBox Width="180" 
                          ItemsSource="{Binding EquipmentList}"
                          SelectedItem="{Binding SelectedEquipment, Mode=TwoWay}"
                          DisplayMemberPath="EquipmentName"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_Equipment}"
                          Margin="0,0,15,0"/>

                <Button Content="{DynamicResource btn_Clear}"
                        MinWidth="90"
                        Padding="10,4"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <DatePicker Width="150" 
                            SelectedDate="{Binding DateFrom}"
                            materialDesign:HintAssist.Hint="{DynamicResource ph_DateFrom}"
                            Margin="0,0,15,0"/>

                <DatePicker Width="150" 
                            SelectedDate="{Binding DateTo}"
                            materialDesign:HintAssist.Hint="{DynamicResource ph_DateTo}"
                            Margin="0,0,15,0"/>


                <TextBox Width="100" 
                         Text="{Binding PriceMin}"
                         materialDesign:HintAssist.Hint="{DynamicResource ph_MinPrice}"
                         Margin="0,0,10,0"/>

                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Width="100" 
                         Text="{Binding PriceMax}"
                         materialDesign:HintAssist.Hint="{DynamicResource ph_MaxPrice}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding purchases}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource dg_Id}" Width="Auto" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Model}" Width="Auto" MinWidth="110" Binding="{Binding ModelName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Vendor}" Width="Auto" MinWidth="110" Binding="{Binding VendorName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Equipment}" Width="Auto" MinWidth="110" Binding="{Binding EquipmentName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Quantity}" Width="Auto" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_UnitPrice}" Width="Auto" Binding="{Binding UnitPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_TotalPrice}" Width="Auto" Binding="{Binding TotalPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Currency}" Width="Auto" Binding="{Binding CurrencyCode}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_PurchaseDate}" Width="Auto" MinWidth="110" Binding="{Binding PurchaseDate}"/>

                    <DataGridTextColumn Header="{DynamicResource dg_Note}" Width="*" Binding="{Binding Note}"/>

                    <DataGridTemplateColumn Header="{DynamicResource dg_Edit}" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        HorizontalAlignment="Center" Width="30" Height="30"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="Pencil" Width="18"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{DynamicResource dg_Delete}" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        HorizontalAlignment="Center" Width="30" Height="30"
                                        Foreground="Red"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="Delete" Width="18"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="{DynamicResource btn_Prev}" Width="45" Height="28" Command="{Binding PrevCommand}"/>
                <TextBlock Text="{Binding CurrentPage}" Margin="20,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="15"/>
                <Button Content="{DynamicResource btn_Next}" Width="45" Height="28" Command="{Binding NextCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>