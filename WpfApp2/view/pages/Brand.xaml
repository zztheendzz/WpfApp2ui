<Page x:Class="WpfApp2.view.pages.Brand"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Brand">

    <Grid>
        <StackPanel>
            <TextBlock Width="150" >brand</TextBlock>
            <DataGrid x:Name="brand" AutoGenerateColumns="true" >

            <DataGrid.Columns>
                <DataGridCheckBoxColumn Binding="{Binding isSelected}" Header="" Width="40"></DataGridCheckBoxColumn>
                <DataGridTextColumn Header="No." Binding="{Binding no}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding model}" Width="*"/>
                <DataGridTextColumn Header="Model Code" Binding="{Binding modelCode}" Width="*"/>
                <DataGridTextColumn Header="Vendor" Binding="{Binding vendor}" Width="*"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding unitPrice}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        </StackPanel>
    </Grid>
</Page>
