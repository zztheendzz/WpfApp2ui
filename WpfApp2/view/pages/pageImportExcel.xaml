<Page x:Class="WpfApp2.view.pages.pageImportExcel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.pages"
      xmlns:vm="clr-namespace:WpfApp2.viewmodel.importExcel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="pageImportExcel">

    <Page.DataContext>
        <vm:ImportExcelVm/>
    </Page.DataContext>

    <!-- ====== UI ====== -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====== FILE PICKER ====== -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBox Width="300"
                     Text="{Binding FilePath}"
                     IsReadOnly="True"
                     Margin="0,0,10,0"/>

            <Button Content="{DynamicResource btn_SelectFile}"
                    Width="100"
                    Command="{Binding BrowseFileCommand}"/>
        </StackPanel>

        <!-- ====== IMPORT BUTTON ====== -->
        <Button Grid.Row="2"
                Content="{DynamicResource btn_Import}"
                Height="35"
                Width="120"
                HorizontalAlignment="Left"
                Command="{Binding InsertCommand}"/>

        <!-- ====== MESSAGE ====== -->
        <TextBlock Grid.Row="4"
                   Text="{Binding Message}"
                   Foreground="Red"
                   TextWrapping="Wrap"/>
    </Grid>
     
</Page>
