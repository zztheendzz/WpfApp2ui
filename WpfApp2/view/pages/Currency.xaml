<Page x:Class="WpfApp2.view.pages.Currency"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Currency">

    <Grid>

        <DataGrid x:Name="currency" AutoGenerateColumns="true" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding no}" Width="*"/>
                <DataGridTextColumn Header="foreign currency" Binding="{Binding foreignCurrency}" Width="*"/>
                <DataGridTextColumn Header="VND" Binding="{Binding vnd}" Width="*"/>
                <!--list category?-->
            </DataGrid.Columns>
        </DataGrid>


    </Grid>
</Page>
