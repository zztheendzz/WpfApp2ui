<Page x:Class="WpfApp2.view.pages.Vendor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Vendor">

    <Grid>
        <DataGrid x:Name="vendor" AutoGenerateColumns="true" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding no}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding nameVendor}" Width="*"/>
                <DataGridTextColumn Header="Currency" Binding="{Binding currency}" Width="*"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="*"/>
                <!--list category?-->
            </DataGrid.Columns>
        </DataGrid>



    </Grid>
</Page>
