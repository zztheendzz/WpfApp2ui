<Page x:Class="WpfApp2.view.analysis.PurchaseAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      xmlns:vm="clr-namespace:WpfApp2.viewmodel.analysis"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PurchaseAnalysis">

    <Page.DataContext>
        <vm:PurchaseAnalysisVm/>
    </Page.DataContext>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Grid Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 1 -->
            <StackPanel Orientation="Horizontal">

                <!-- MODEL -->
                <ComboBox Width="300"
          Margin="10"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"
          ItemsSource="{Binding ModelSuggestions}"
          Text="{Binding SearchModelText, UpdateSourceTrigger=PropertyChanged}"
          SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
          DisplayMemberPath="Text" 
          IsDropDownOpen="{Binding IsDropDownOpenM}"
          PreviewMouseDown="ComboBox_PreviewMouseDown"
          materialDesign:HintAssist.Hint="Model" SelectionChanged="ComboBox_SelectionChanged">
                    <!--<ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>-->
                </ComboBox>

                <!-- VENDOR -->
                <ComboBox Width="300"
              Margin="10"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              ItemsSource="{Binding VendorSuggestions}"
              Text="{Binding SearchVendorText, UpdateSourceTrigger=PropertyChanged}"
              SelectedItem="{Binding SelectedVendor, Mode=TwoWay}"
              DisplayMemberPath="Text" 
              IsDropDownOpen="{Binding IsDropDownOpenV}"
              PreviewMouseDown="ComboBox_PreviewMouseDown"
              materialDesign:HintAssist.Hint="Vendor" SelectionChanged="ComboBox_SelectionChanged_1">

                    <!--<ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>-->
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="GotFocus">
                            <i:InvokeCommandAction Command="{Binding VendorFocusCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ComboBox>

                <!-- EQUIPMENT -->
                <ComboBox Width="300"
              Margin="10"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              ItemsSource="{Binding EquipmentSuggestions}"
              Text="{Binding SearchEquipmentText, UpdateSourceTrigger=PropertyChanged}"
              SelectedItem="{Binding SelectedEquipment, Mode=TwoWay}"
              IsDropDownOpen="{Binding IsDropDownOpenE}"
              DisplayMemberPath="Text" 
              PreviewMouseDown="ComboBox_PreviewMouseDown"
              materialDesign:HintAssist.Hint="Equipment">

                    <!--<ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>-->

                </ComboBox>
                <!-- BUTTON -->
                <Button Content="Search"
            Margin="10,0,0,0"
            Command="{Binding SearchCommand}"/>

                <!-- Clear -->
                <Button Content="Clear"
                          Margin="10"
            Command="{Binding ClearCommand}"/>

            </StackPanel>

            <!-- Row 2 -->
            <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                          Margin="10,0,0,10"
                VerticalAlignment="Center">

                <DatePicker Width="140"
                    SelectedDate="{Binding SelectedDateFrom}"
                    materialDesign:HintAssist.Hint="Date From"/>

                <DatePicker Width="140"
                    Margin="10,0,0,0"
                    SelectedDate="{Binding SelectedDateTo}"
                    materialDesign:HintAssist.Hint="Date To"/>

                <TextBox Width="80"
                 Margin="30,0,0,0"
                 Text="PriceMin"
                 materialDesign:HintAssist.Hint="Min Price"/>

                <xctk:DoubleUpDown Value="{Binding PriceMin, Mode=TwoWay}" 
                   ClipValueToMinMax="True"
                   Minimum="0"
                   Width="80"
                   Margin="10,0,0,0"/>
                
                
                <TextBox Width="80"
                 Margin="30,0,0,0"
                 Text="PriceMax"
                 materialDesign:HintAssist.Hint="Max Price"/>

                <xctk:DoubleUpDown Value="{Binding PriceMax, Mode=TwoWay}" 
                   ClipValueToMinMax="True"
                   Width="80"
                   Margin="10,0,0,0"
                   Minimum="0"/>
                <TextBlock Text="{Binding SelectedCount, StringFormat=Total Record: {0}}"
                           Margin="30,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"/>

            </StackPanel>
        </Grid>


        <!-- TABLE + PAGINATION -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- DATA GRID -->
            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding PurchaseDtos}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"/>

                    <DataGridTextColumn Header="Model"
                                        Binding="{Binding ModelName}"/>

                    <DataGridTextColumn Header="Vendor"
                                        Binding="{Binding VendorName}"/>

                    <DataGridTextColumn Header="Equipment"
                                        Binding="{Binding EquipmentName}"/>

                    <DataGridTextColumn Header="Quantity"
                                        Binding="{Binding Quantity}"/>

                    <DataGridTextColumn Header="UnitPrice"
                                        Binding="{Binding UnitPrice}"/>

                    <DataGridTextColumn Header="Tota lPrice"
                                        Binding="{Binding TotalPrice}"/>

                    <DataGridTextColumn Header="Currency"
                                        Binding="{Binding CurrencyCode}"/>

                    <DataGridTextColumn Header="Purchase Date"
                                       Binding="{Binding PurchaseDate}"/>

                    <DataGridTextColumn Header="Create At"
                                       Binding="{Binding CreateAt}"/>

                    <DataGridTextColumn Header="User"
                                       Binding="{Binding UserId}"/>


                    <DataGridTextColumn Header="Note"
                                        Binding="{Binding Note}"/>
                </DataGrid.Columns>
            </DataGrid>


            <!-- PAGINATION -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="◀"
                        Width="45"
                        Height="25"
                        Command="{Binding PrevCommand}"/>

                <TextBlock Text="{Binding CurrentPage}"
                           Margin="10,0"
                           VerticalAlignment="Center"
                           FontSize="14"/>

                <Button Content="▶"
                        Width="45"
                        Height="25"
                        Command="{Binding NextCommand}"/>

            </StackPanel>

        </Grid>

    </Grid>

</Page>