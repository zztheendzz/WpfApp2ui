<Page x:Class="WpfApp2.view.analysis.PurchaseAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      xmlns:vm="clr-namespace:WpfApp2.viewmodel.analysis"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PurchaseAnalysis">

    <Page.DataContext>
        <vm:PurchaseAnalysisVm/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <ComboBox Width="300"
                          Margin="10"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          ItemsSource="{Binding ModelSuggestions}"
                          Text="{Binding SearchModelText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                          DisplayMemberPath="Text" 
                          IsDropDownOpen="{Binding IsDropDownOpenM}"
                          PreviewMouseDown="ComboBox_PreviewMouseDown"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_ModelName}" 
                          SelectionChanged="ComboBox_SelectionChanged">
                </ComboBox>

                <ComboBox Width="300"
                          Margin="10"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          ItemsSource="{Binding VendorSuggestions}"
                          Text="{Binding SearchVendorText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedVendor, Mode=TwoWay}"
                          DisplayMemberPath="Text" 
                          IsDropDownOpen="{Binding IsDropDownOpenV}"
                          PreviewMouseDown="ComboBox_PreviewMouseDown"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_Vendor}" 
                          SelectionChanged="ComboBox_SelectionChanged_1">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="GotFocus">
                            <i:InvokeCommandAction Command="{Binding VendorFocusCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ComboBox>

                <ComboBox Width="300"
                          Margin="10"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          ItemsSource="{Binding EquipmentSuggestions}"
                          Text="{Binding SearchEquipmentText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedEquipment, Mode=TwoWay}"
                          IsDropDownOpen="{Binding IsDropDownOpenE}"
                          DisplayMemberPath="Text" 
                          PreviewMouseDown="ComboBox_PreviewMouseDown"
                          materialDesign:HintAssist.Hint="{DynamicResource ph_Equipment}"/>

                <Button Content="{DynamicResource btn_Search}"
                        Margin="10,0,0,0"
                        Command="{Binding SearchCommand}"/>

                <Button Content="{DynamicResource btn_Clear}"
                        Margin="10"
                        Command="{Binding ClearCommand}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,0,10" VerticalAlignment="Center">
                <DatePicker Width="140"
                            SelectedDate="{Binding SelectedDateFrom}"
                            materialDesign:HintAssist.Hint="{DynamicResource ph_DateFrom}"/>

                <DatePicker Width="140"
                            Margin="10,0,0,0"
                            SelectedDate="{Binding SelectedDateTo}"
                            materialDesign:HintAssist.Hint="{DynamicResource ph_DateTo}"/>

                <TextBlock Text="{DynamicResource ph_MinPrice}" VerticalAlignment="Center" Margin="30,0,0,0"/>
                <xctk:DoubleUpDown Value="{Binding PriceMin, Mode=TwoWay}" 
                                   ClipValueToMinMax="True"
                                   Minimum="0"
                                   Width="100"
                                   Margin="10,0,0,0"/>

                <TextBlock Text="{DynamicResource ph_MaxPrice}" VerticalAlignment="Center" Margin="30,0,0,0"/>
                <xctk:DoubleUpDown Value="{Binding PriceMax, Mode=TwoWay}" 
                                   ClipValueToMinMax="True"
                                   Width="100"
                                   Margin="10,0,0,0"
                                   Minimum="0"/>

                <StackPanel Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource lbl_TotalRecords}" FontSize="14"/>
                    <TextBlock Text="{Binding SelectedCount}" Margin="5,0,0,0" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding PurchaseDtos}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource dg_Id}" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Model}" Binding="{Binding ModelName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Vendor}" Binding="{Binding VendorName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Equipment}" Binding="{Binding EquipmentName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Quantity}" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_UnitPrice}" Binding="{Binding UnitPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_TotalPrice}" Binding="{Binding TotalPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Currency}" Binding="{Binding CurrencyCode}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_PurchaseDate}" Binding="{Binding PurchaseDate}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_CreateAt}" Binding="{Binding CreateAt}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_User}" Binding="{Binding UserId}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Note}" Width="*" Binding="{Binding Note}"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{DynamicResource btn_Prev}" Width="45" Height="25" Command="{Binding PrevCommand}"/>
                <TextBlock Text="{Binding CurrentPage}" Margin="10,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                <Button Content="{DynamicResource btn_Next}" Width="45" Height="25" Command="{Binding NextCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>