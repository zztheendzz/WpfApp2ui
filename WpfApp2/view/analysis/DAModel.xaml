<Page x:Class="WpfApp2.view.analysis.DAModel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DAModel">

    <Grid>
        <Grid>
        <DataGrid x:Name="category" AutoGenerateColumns="true" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding no}" Width="*"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding model}" Width="*"/>
                    <DataGridTextColumn Header="Model Code" Binding="{Binding modelCode}" Width="*"/>
                    <DataGridTextColumn Header="Highest price" Binding="{Binding model}" Width="*"/>
                    <DataGridTextColumn Header="Lowest price" Binding="{Binding modelCode}" Width="*"/>
                    <DataGridTextColumn Header="Average price" Binding="{Binding brand}" Width="*"/>

            </DataGrid.Columns>
        </DataGrid>
        <lvc:CartesianChart Name="MyChart">
            <lvc:CartesianChart.Series>

                <lvc:ColumnSeries 
                    Title="Giá mua"
                    Values="{Binding ChartValues}" />

            </lvc:CartesianChart.Series>

            <lvc:CartesianChart.AxisX>
                <lvc:Axis Title="Model" Labels="{Binding Labels}" />

            </lvc:CartesianChart.AxisX>

            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Giá" />
                
            </lvc:CartesianChart.AxisY>

        </lvc:CartesianChart>
        </Grid>
    </Grid>
</Page>
