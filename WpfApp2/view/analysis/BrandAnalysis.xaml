<Page x:Class="WpfApp2.view.analysis.BrandAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BrandAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                <TextBlock Text="{DynamicResource lbl_Brand}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Width="300"
                          Margin="10"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          ItemsSource="{Binding SearchSuggestions}"
                          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                          DisplayMemberPath="Text" 
                          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                          SelectionChanged="ComboBox_SelectionChanged">
                </ComboBox>

                <Button Content="{DynamicResource btn_Analyze}"
                        Width="100"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeCommand}"/>

            </StackPanel>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_TotalPurchaseValue}"
                                   Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.TotalPrice}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel >
                        <TextBlock Text="{DynamicResource lbl_TotalParts}"
                                   Foreground="White" />
                        <TextBlock Text="{Binding Analysis.TotalQuantity}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_UsageRate}"
                                   Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.UsageRate}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                <TextBlock FontWeight="Bold" Text="{DynamicResource lbl_PurchasedPartsList}"/>
                <TextBlock FontWeight="Bold" Text=": "/>
                <TextBlock FontWeight="Bold" Text="{Binding Analysis.BrandName}"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
                      AutoGenerateColumns="False" IsReadOnly="True" >
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Id}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Id}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding ModelName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Model}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding VendorName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Vendor}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding EquipmentName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Equipment}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Quantity}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Quantity}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding UnitPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_UnitPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding TotalPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_TotalPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding CurrencyCode}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Currency}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding PurchaseDate}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_PurchaseDate}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding CreateAt}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_CreateAt}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding UserId}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_User}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="*" Binding="{Binding Note}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Note}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </Grid>
</Page>