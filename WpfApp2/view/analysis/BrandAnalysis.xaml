<Page x:Class="WpfApp2.view.analysis.BrandAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BrandAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <!-- Filter -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">


                <ComboBox Width="300"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"
          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
          ItemsSource="{Binding SearchSuggestions}"
          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
          IsSynchronizedWithCurrentItem="False">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>




                <Button Content="Phân tích"
                Width="100"
                Margin="10,0,0,0"
                Command="{Binding AnalyzeCommand}"/>

            </StackPanel>


            <!-- Summary -->
            <Grid Margin="0,10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Total Amount -->
                <Border Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Tổng giá trị mua"
                           Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.TotalPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Part Count -->
                <Border Grid.Column="1"
                Background="#2C3E50"
                Margin="5"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Số linh kiện"
                           Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.TotalQuantity}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Usage Rate -->
                <Border Grid.Column="2"
                Background="#2C3E50"
                Margin="5"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Tỷ lệ sử dụng"
                           Foreground="White"/>
                        <TextBlock Text="{Binding }"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

            </Grid>


            <!-- Purchased Parts -->
            <TextBlock FontWeight="Bold" Margin="0,20,0,5">
                <Run Text="Danh sách linh kiện đã mua - "/>
                <Run Text="{Binding Analysis.BrandName}"/>
            </TextBlock>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
              AutoGenerateColumns="False" IsReadOnly="True" >

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                       Binding="{Binding Id}"/>

                    <DataGridTextColumn Header="Model"
                                Binding="{Binding ModelName}"/>

                    <DataGridTextColumn Header="Vendor"
                                Binding="{Binding VendorName}"/>

                    <DataGridTextColumn Header="Equipment"
                                Binding="{Binding EquipmentName}"/>

                    <DataGridTextColumn Header="Price"
                                Binding="{Binding TotalPrice}"/>

                    <DataGridTextColumn Header="Date"
                                Binding="{Binding PurchaseDate}"/>
                    
                    <DataGridTextColumn Header="Vendor"
                                       Binding="{Binding VendorName}"/>

                    <DataGridTextColumn Header="Equipment"
                                       Binding="{Binding EquipmentName}"/>

                    <DataGridTextColumn Header="Quantity"
                                       Binding="{Binding Quantity}"/>

                    <DataGridTextColumn Header="UnitPrice"
                                       Binding="{Binding UnitPrice}"/>

                    <DataGridTextColumn Header="Tota lPrice"
                                       Binding="{Binding TotalPrice}"/>

                    <DataGridTextColumn Header="Currency"
                                       Binding="{Binding CurrencyCode}"/>

                    <DataGridTextColumn Header="Purchase Date"
                                      Binding="{Binding PurchaseDate}"/>

                    <DataGridTextColumn Header="Creat At"
                                      Binding="{Binding CreateAt}"/>

                    <DataGridTextColumn Header="User"
                                      Binding="{Binding UserId}"/>


                    <DataGridTextColumn Header="Note"
                                       Binding="{Binding Note}"/>



                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>
</Page>
