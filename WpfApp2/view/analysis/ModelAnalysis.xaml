<Page x:Class="WpfApp2.view.analysis.ModelAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ModelAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <!-- Filter -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Model:"
               VerticalAlignment="Center"
               Margin="0,0,10,0"/>

                <!-- Ô tìm kiếm -->
                <!--<TextBox Width="150"
             Margin="0,0,10,0"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>-->

                <!-- Combobox model -->
                <ComboBox Width="300"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"
          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
          ItemsSource="{Binding SearchSuggestions}"
          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
          DisplayMemberPath="Text">

                </ComboBox>


                <Button Content="Phân tích"
            Width="100"
            Margin="10,0,0,0"
            Command="{Binding AnalyzeModelCommand}"/>
            </StackPanel>


            <!-- Price Summary -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Giá gần nhất" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.LatestPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Giá thấp nhất" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.MinPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Giá cao nhất" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.MaxPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!--<Border Grid.Column="3" Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Giá trung bình" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.AvgPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>-->
            </Grid>


            <!-- Vendor Comparison -->
            <TextBlock Text="So sánh giá theo nhà cung cấp"
               FontWeight="Bold"
               Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding Analysis.Vendors}" 
              IsReadOnly="True"
              AutoGenerateColumns="False"
              Height="200">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Vendor"
                                Binding="{Binding VendorName}"/>

                    <!--<DataGridTextColumn Header="Giá gần nhất"
                                Binding="{Binding LatestPrice}"/>-->

                    <DataGridTextColumn Header="Giá thấp nhất"
                                Binding="{Binding MinPrice}"/>

                    <DataGridTextColumn Header="Giá cao nhất"
                                Binding="{Binding MaxPrice}"/>
                </DataGrid.Columns>
            </DataGrid>


            <!-- Purchase History -->
            <TextBlock Text="Lịch sử mua hàng"
               FontWeight="Bold"
               Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
              AutoGenerateColumns="False" IsReadOnly="True" >

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"/>

                    <DataGridTextColumn Header="Vendor"
                                        Binding="{Binding VendorName}"/>

                    <DataGridTextColumn Header="Equipment"
                                        Binding="{Binding EquipmentName}"/>

                    <DataGridTextColumn Header="Quantity"
                                        Binding="{Binding Quantity}"/>

                    <DataGridTextColumn Header="UnitPrice"
                                        Binding="{Binding UnitPrice}"/>

                    <DataGridTextColumn Header="Tota lPrice"
                                        Binding="{Binding TotalPrice}"/>

                    <DataGridTextColumn Header="Currency"
                                        Binding="{Binding CurrencyCode}"/>

                    <DataGridTextColumn Header="Purchase Date"
                                       Binding="{Binding PurchaseDate}"/>

                    <DataGridTextColumn Header="Creat At"
                                       Binding="{Binding CreateAt}"/>

                    <DataGridTextColumn Header="User"
                                       Binding="{Binding UserId}"/>


                    <DataGridTextColumn Header="Note"
                                        Binding="{Binding Note}"/>

                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>




    </Grid>
</Page>
