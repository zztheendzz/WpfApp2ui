<Page x:Class="WpfApp2.view.analysis.ModelAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="ModelAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{DynamicResource lbl_Model}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"/>

                <ComboBox Width="300"
                          Margin="10"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                          ItemsSource="{Binding SearchSuggestions}"
                          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                          DisplayMemberPath="Text"/>

                <Button Content="{DynamicResource btn_Analyze}"
                        Width="120"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeModelCommand}"/>
            </StackPanel>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_LatestPrice}" Foreground="#BDC3C7" FontSize="12"/>
                        <TextBlock Text="{Binding Analysis.LatestPrice}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_MinPrice}" Foreground="#BDC3C7" FontSize="12"/>
                        <TextBlock Text="{Binding Analysis.MinPrice}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_MaxPrice}" Foreground="#BDC3C7" FontSize="12"/>
                        <TextBlock Text="{Binding Analysis.MaxPrice}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{DynamicResource lbl_VendorComparison}" FontWeight="Bold" FontSize="14" Margin="0,20,0,5"/>
            <DataGrid ItemsSource="{Binding Analysis.Vendors}" 
                      IsReadOnly="True" AutoGenerateColumns="False" 
                      MaxHeight="150" ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding VendorName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Vendor}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="Auto" MinWidth="150" Binding="{Binding MinPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource lbl_MinPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="Auto" MinWidth="150" Binding="{Binding MaxPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource lbl_MaxPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="{DynamicResource lbl_PurchaseHistory}" FontWeight="Bold" FontSize="14" Margin="0,20,0,5"/>
            <DataGrid ItemsSource="{Binding Analysis.Items}"
                      AutoGenerateColumns="False" IsReadOnly="True" 
                      MaxHeight="300" ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Id}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Id}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="Auto" MinWidth="100" Binding="{Binding VendorName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Vendor}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="Auto" MinWidth="100" Binding="{Binding EquipmentName}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Equipment}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding Quantity}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Quantity}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding UnitPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_UnitPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding TotalPrice}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_TotalPrice}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding CurrencyCode}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Currency}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding PurchaseDate}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_PurchaseDate}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding CreateAt}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_CreateAt}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding UserId}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_User}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTextColumn Width="*" Binding="{Binding Note}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource dg_Note}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </Grid>
</Page>