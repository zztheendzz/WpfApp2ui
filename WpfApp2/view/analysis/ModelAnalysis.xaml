<Page x:Class="WpfApp2.view.analysis.ModelAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ModelAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{DynamicResource lbl_Model}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Width="300"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                          ItemsSource="{Binding SearchSuggestions}"
                          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                          DisplayMemberPath="Text">
                </ComboBox>

                <Button Content="{DynamicResource btn_Analyze}"
                        Width="100"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeModelCommand}"/>
            </StackPanel>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_LatestPrice}" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.LatestPrice}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_MinPrice}" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.MinPrice}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource lbl_MaxPrice}" Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.MaxPrice}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{DynamicResource lbl_VendorComparison}"
                       FontWeight="Bold"
                       Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding Analysis.Vendors}" 
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      Height="150">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource dg_Vendor}" Binding="{Binding VendorName}"/>
                    <DataGridTextColumn Header="{DynamicResource lbl_MinPrice}" Binding="{Binding MinPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource lbl_MaxPrice}" Binding="{Binding MaxPrice}"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="{DynamicResource lbl_PurchaseHistory}"
                       FontWeight="Bold"
                       Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
                      AutoGenerateColumns="False" IsReadOnly="True" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource dg_Id}" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Vendor}" Binding="{Binding VendorName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Equipment}" Binding="{Binding EquipmentName}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Quantity}" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_UnitPrice}" Binding="{Binding UnitPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_TotalPrice}" Binding="{Binding TotalPrice}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Currency}" Binding="{Binding CurrencyCode}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_PurchaseDate}" Binding="{Binding PurchaseDate}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_CreateAt}" Binding="{Binding CreateAt}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_User}" Binding="{Binding UserId}"/>
                    <DataGridTextColumn Header="{DynamicResource dg_Note}" Width="*" Binding="{Binding Note}"/>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </Grid>
</Page>