<Page x:Class="WpfApp2.view.analysis.EquipmentAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EquipmentAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <!-- Filter -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                <TextBlock Text="Equipment:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

                    <ComboBox Width="300"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                          ItemsSource="{Binding SearchSuggestions}"
                          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>

                <Button Content="Phân tích"
                Width="100"
                Margin="10,0,0,0"
                Command="{Binding AnalyzeCommand}"/>

            </StackPanel>


            <!-- Summary -->
            <Grid Margin="0,10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Total Cost -->
                <Border Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Tổng chi phí mua"
                           Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.TotalPrice}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Part Count -->
                <Border Grid.Column="1"
                Background="#2C3E50"
                Margin="5"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Số linh kiện sử dụng"
                           Foreground="White"/>
                        <TextBlock Text="{Binding Analysis.TotalQuantity}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

            </Grid>


            <!-- Parts List -->
            <TextBlock Text="Danh sách linh kiện sử dụng"
               FontWeight="Bold"
               Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
              AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"/>

                    <DataGridTextColumn Header="Model"
                                        Binding="{Binding ModelName}"/>

                    <DataGridTextColumn Header="Vendor"
                                        Binding="{Binding VendorName}"/>

                    <DataGridTextColumn Header="Quantity"
                                        Binding="{Binding Quantity}"/>

                    <DataGridTextColumn Header="UnitPrice"
                                        Binding="{Binding UnitPrice}"/>

                    <DataGridTextColumn Header="Tota lPrice"
                                        Binding="{Binding TotalPrice}"/>

                    <DataGridTextColumn Header="Currency"
                                        Binding="{Binding CurrencyCode}"/>

                    <DataGridTextColumn Header="Purchase Date"
                                       Binding="{Binding PurchaseDate}"/>

                    <DataGridTextColumn Header="Creat At"
                                       Binding="{Binding CreateAt}"/>

                    <DataGridTextColumn Header="User"
                                       Binding="{Binding UserId}"/>


                    <DataGridTextColumn Header="Note"
                                        Binding="{Binding Note}"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>
</Page>
