<Page x:Class="WpfApp2.view.analysis.VendorAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="VendorAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{StaticResource lbl_Vendor}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox Width="300"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                          ItemsSource="{Binding SearchSuggestions}"
                          Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                          DisplayMemberPath="Text"/>

                <Button Content="{DynamicResource btn_Analyze}"
                        Width="100"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeModelCommand}"/>
            </StackPanel>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{StaticResource lbl_TotalPurchaseValue}" Foreground="#BDC3C7"/>
                        <TextBlock Text="{Binding Analysis.TotalPrice}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{StaticResource lbl_SupplyCount}" Foreground="#BDC3C7"/>
                        <TextBlock Text="{Binding Analysis.SupplyCount}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2C3E50" Margin="5" Padding="15" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="{StaticResource lbl_TotalParts}" Foreground="#BDC3C7"/>
                        <TextBlock Text="{Binding Analysis.TotalQuantity}"
                                   FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{StaticResource lbl_PurchasedPartsList}"
                       FontSize="16" FontWeight="Bold"
                       Margin="0,20,0,10"/>

            <DataGrid ItemsSource="{Binding Analysis.Items}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      Background="White"
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{StaticResource dg_Id}" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="{StaticResource dg_Model}" Binding="{Binding ModelName}" Width="*"/>
                    <DataGridTextColumn Header="{StaticResource dg_Equipment}" Binding="{Binding EquipmentName}" Width="*"/>
                    <DataGridTextColumn Header="{StaticResource dg_Quantity}" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="{StaticResource dg_UnitPrice}" Binding="{Binding UnitPrice}" Width="100"/>
                    <DataGridTextColumn Header="{StaticResource dg_TotalPrice}" Binding="{Binding TotalPrice}" Width="120"/>
                    <DataGridTextColumn Header="{StaticResource dg_Currency}" Binding="{Binding CurrencyCode}"/>
                    <DataGridTextColumn Header="{StaticResource dg_PurchaseDate}" Binding="{Binding PurchaseDate, StringFormat=\{0:dd/MM/yyyy\}}"/>
                    <DataGridTextColumn Header="{StaticResource dg_CreateAt}" Binding="{Binding CreateAt, StringFormat=\{0:dd/MM/yyyy\}}"/>
                    <DataGridTextColumn Header="{StaticResource dg_User}" Binding="{Binding UserId}"/>
                    <DataGridTextColumn Header="{StaticResource dg_Note}" Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </Grid>
</Page>