<Page x:Class="WpfApp2.view.analysis.VendorAnalysis"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="VendorAnalysis">

    <Grid>
        <StackPanel Margin="20">

            <!-- Filter Vendor -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                <TextBlock Text="Vendor:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

                <ComboBox Width="200"
                  ItemsSource="{Binding Vendors}"
                  SelectedItem="{Binding SelectedVendor}"
                  DisplayMemberPath="VendorName"/>

                <Button Content="Phân tích"
                Width="100"
                Margin="10,0,0,0"
                Command="{Binding AnalyzeCommand}"/>

            </StackPanel>


            <!-- Summary -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Total Purchase -->
                <Border Background="#2C3E50" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Tổng giá trị mua"
                           Foreground="White"/>
                        <TextBlock Text="{Binding TotalAmount}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Supply Count -->
                <Border Grid.Column="1"
                Background="#2C3E50"
                Margin="5"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Số lần cung cấp"
                           Foreground="White"/>
                        <TextBlock Text="{Binding SupplyCount}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Part Count -->
                <Border Grid.Column="2"
                Background="#2C3E50"
                Margin="5"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Số linh kiện"
                           Foreground="White"/>
                        <TextBlock Text="{Binding PartCount}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

            </Grid>


            <!-- Purchased Parts List -->
            <TextBlock Text="Danh sách linh kiện đã mua"
               FontWeight="Bold"
               Margin="0,20,0,5"/>

            <DataGrid ItemsSource="{Binding PurchasedParts}"
              AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Model"
                                Binding="{Binding ModelName}"/>

                    <DataGridTextColumn Header="Brand"
                                Binding="{Binding BrandName}"/>

                    <DataGridTextColumn Header="Equipment"
                                Binding="{Binding EquipmentName}"/>

                    <DataGridTextColumn Header="Category"
                                Binding="{Binding CategoryName}"/>

                    <DataGridTextColumn Header="Price"
                                Binding="{Binding Price}"/>

                    <DataGridTextColumn Header="Date"
                                Binding="{Binding Date}"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>
</Page>
