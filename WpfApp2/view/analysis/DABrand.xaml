<Page x:Class="WpfApp2.view.analysis.DABrand"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:local="clr-namespace:WpfApp2.view.analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DABrand">

    <Grid>

        <DataGrid x:Name="category" AutoGenerateColumns="true" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding no}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding model}" Width="*"/>
                <DataGridTextColumn Header="Model Code" Binding="{Binding modelCode}" Width="*"/>
                <DataGridTextColumn Header="Total Amount" Binding="{Binding totalAmount}" Width="*"/>
                <DataGridTextColumn Header="Usage rate" Binding="{Binding usageRate}" Width="*"/>

            </DataGrid.Columns>
        </DataGrid>


    </Grid>
</Page>
