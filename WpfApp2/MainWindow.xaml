<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition  Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0" ShowGridLines="True">


            <StackPanel>
                <TextBox>Menu</TextBox>
                <Grid>
                    <Button>puchasehistory</Button> 
                </Grid>
                <Grid>
                    <Button>category</Button>
                </Grid>
                <Grid>
                    <Button>vendor</Button>
                </Grid>
                <Grid>
                    <Button>log out</Button>
                </Grid>
            </StackPanel>
            
        </Grid>
        <Grid Grid.Column="1" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition  Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Grid ShowGridLines="True" Grid.Column="0" Margin="5,0,0,0">
                <TextBox VerticalAlignment="Top" Height="20" Width="100" Background="White"></TextBox>
            </Grid>
            <Grid ShowGridLines="True" Grid.Column="1" Margin="5,0,0,0">
                <Button  VerticalAlignment="Top" Height="20" Width="100" >search</Button>
            </Grid>



        </Grid>

    </Grid>
</Window>
