<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- TopBar -->
        <Border Grid.Row="0"
        Grid.ColumnSpan="2"
        Background="LightSlateGray"
        Padding="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <StackPanel Margin="0,0,10,0"
                        VerticalAlignment="Center">

                        <Image Source="/Images/logo.jpg"
                       Width="35"
                       Height="25"
                       HorizontalAlignment="Center"/>

                        <TextBlock Text="Automation"
                           FontSize="10"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Price Management System"
                       Foreground="White"
                       FontSize="18"
                       VerticalAlignment="Center"/>
                </StackPanel>


                <!-- Global Search -->
                <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                    <ComboBox Width="300"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              IsDropDownOpen="{Binding IsSearchDropDownOpen}"
              ItemsSource="{Binding SearchSuggestions}"
              Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
              SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Source}"
                               FontWeight="Bold"
                               Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Text}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                    </ComboBox>

                    <Button Width="60"
            Height="30"
            Margin="5,0,0,0"
            Command="{Binding GlobalSearchCommand}">

                        <materialDesign:PackIcon Kind="Magnify"
                                 Width="20"
                                 Height="20"/>
                    </Button>

                </StackPanel>


                <!-- User -->
                <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">

                    <materialDesign:PackIcon Kind="Account"
                                     Width="20"
                                     Height="20"
                                     Margin="0,0,5,0"/>

                    <TextBlock Text="Admin"
                       Foreground="White"
                       VerticalAlignment="Center"/>

                </StackPanel>

            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
              Grid.Column="0"
              VerticalScrollBarVisibility="Auto">
            <!-- Sidebar -->
            <StackPanel Grid.Row="1"
                Grid.Column="0"
                Background="#34495E">

                <!-- Inquiry -->
                <Expander Header="Inquiry / Analysis"
                  Foreground="Black">

                    <StackPanel>

                        <Button Content="Price Overview" Command="{Binding ShowPuchaseHistoryPageCommand }"
                        Height="35"/>

                        <Button Content="Model Price Analysis" Command="{Binding ShowModelAnalysisCommand}"
                        Height="35" />

                        <Button Content="Vendor Analysis" Command="{Binding ShowVendorAnalysisCommand}"
                        Height="35"/>

                        <Button Content="Brand Analysis" Command="{Binding ShowBrandAnalysisCommand}"
                        Height="35"/>

                        <Button Content="Equipment Analysis" Command="{Binding ShowEquipmentAnalysisCommand}"
                        Height="35"/>

                    </StackPanel>

                </Expander>

                <!-- Data Management -->
                <Expander Header="Data Management" 
                  Foreground="Black">
                    <StackPanel  >
                        <Button  Content="Model" Height="35" Command="{Binding ShowModelPageCommand}"/>
                        <Button  Content="Brand" Height="35" Command="{Binding ShowBrandlPageCommand}"/>
                        <Button Content="Vendor" Height="35" Command="{Binding ShowVendorPageCommand}" />
                        <Button Content="Equipment" Height="35" Command="{Binding ShowEquipmentPageCommand}" />
                        <Button Content="Category" Height="35" Command="{Binding ShowCategoryPageCommand}" />
                        <Button Content="Purchase History" Height="35" Command="{Binding ShowPuchaseHistoryPageCommand}" />
                        <Button Content="Currency" Height="35" Command="{Binding ShowCurrencyPageCommand}"/>
                    </StackPanel>
                </Expander>

                <!-- Price Management -->
                <Expander Header="Price Management"
                  Foreground="Black">

                    <StackPanel>

                        <Button Content="Register Price" Height="35"/>
                        <Button Content="Edit Price" Height="35"/>
                        <Button Content="Delete Price" Height="35"/>

                    </StackPanel>

                </Expander>

                <!-- Excel -->
                <Expander Header="Excel"
                  Foreground="Black">

                    <StackPanel>

                        <Button Content="Excel Upload" Height="35" Command="{Binding ShowImportExcelCommand}"  />

                    </StackPanel>

                </Expander>

                <!-- Settings -->
                <Expander Header="Settings"
                  Foreground="Black">

                    <StackPanel>

                        <Button Content="Database Backup" Height="35"/>
                        <Button Content="User" Height="35"/>
                        <Button Content="Language" Height="35"/>
                    </StackPanel>

                </Expander>

            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1" Grid.Column="1">

                <Grid>
            <Frame   Content="{Binding CurrentPage}"
           NavigationUIVisibility="Hidden"/>
            </Grid>

        </Grid>
        <!-- Main Frame -->

    </Grid>
</Window>
